# Variables de entorno — copiar a .env y rellenar

# LLM principal (clasificación, retrieval, generación)
GROQ_API_KEY=

# Juez de evaluación RAGAS (no requerido en producción)
ANTHROPIC_API_KEY=

# Neo4j — sin NEO4J_PASSWORD el grafo queda desactivado
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Panel de administración
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
JWT_SECRET_KEY=

# Servidor
BASE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=*
